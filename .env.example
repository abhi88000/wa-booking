# ============================================================
# WhatsApp Booking SaaS — Environment Variables
# ============================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# Docker Compose reads .env automatically.

# ── Database ───────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres

# ── Security ──────────────────────────────────────────────
# IMPORTANT: Change this to a random string (min 32 chars)
# Generate one: openssl rand -hex 32
JWT_SECRET=change-this-to-a-secure-random-string

# ── WhatsApp ──────────────────────────────────────────────
# Webhook verification token (set same in Meta Developer Console)
WA_VERIFY_TOKEN=bookingbot-verify-2024

# ── URLs ──────────────────────────────────────────────────
APP_URL=https://api.futurezminds.in
CORS_ORIGINS=https://book.futurezminds.in,https://hub.futurezminds.in,http://localhost:3000,http://localhost:3001

# ── Payments (optional — skip if not using) ───────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# ── n8n (optional — skip if not using) ────────────────────
# N8N_USER=admin
# N8N_PASSWORD=admin
