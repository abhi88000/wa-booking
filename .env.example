# ============================================================
# WhatsApp Booking SaaS — Environment Variables
# ============================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# Docker Compose reads .env automatically.

# ── Database ───────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=<generate-a-strong-password>

# ── Security ───────────────────────────────────────────────
# IMPORTANT: Change this to a random string (min 32 chars)
# Generate one: openssl rand -hex 32
JWT_SECRET=<generate-with-openssl-rand-hex-32>

# ── WhatsApp ───────────────────────────────────────────────
# Webhook verification token (set same in Meta Developer Console)
WA_VERIFY_TOKEN=<any-random-string>

# ── URLs ───────────────────────────────────────────────────
APP_URL=https://api.yourdomain.com
CORS_ORIGINS=https://book.yourdomain.com,https://hub.yourdomain.com,http://localhost:3000,http://localhost:3001

# ── Payments (optional — skip if not using) ────────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
